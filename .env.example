# Hyperliquid credentials
HYPERLIQUID_PRIVATE_KEY=0x_your_api_wallet_private_key_here
HYPERLIQUID_ACCOUNT_ADDRESS=0x_your_api_wallet_address_here
HYPERLIQUID_MAIN_ADDRESS=0x_your_main_account_address_here

# Trading settings
TRADING_COIN=BTC
POSITION_SIZE_USD=100
LEVERAGE=3

# Dashboard
DASHBOARD_PORT=8080

# Set to "true" to use Hyperliquid testnet instead of mainnet
TESTNET=false

# Set to "true" to skip real orders (simulate only)
DRY_RUN=true
