# Anthropic API key — prevents OAuth token expiry issues
# Get yours at: https://console.anthropic.com/settings/api-keys
ANTHROPIC_API_KEY=sk-ant-...

# Discord bot token + channel ID for error alerts (optional)
DISCORD_BOT_TOKEN=MTQ...
DISCORD_CHANNEL_ID=1234567890123456789

# Hyperliquid credentials
HYPERLIQUID_PRIVATE_KEY=0x_your_api_wallet_private_key_here
HYPERLIQUID_ACCOUNT_ADDRESS=0x_your_api_wallet_address_here
HYPERLIQUID_MAIN_ADDRESS=0x_your_main_account_address_here

# Trading settings
TRADING_COIN=BTC
POSITION_SIZE_USD=100
LEVERAGE=3

# Timing
CYCLE_INTERVAL_MINUTES=60   # How often Claude analyzes charts (minutes)
POSITION_MAX_HOURS=4        # Force-close positions after this many hours

# Emergency thresholds (triggers urgent MAGI session bypassing normal cycle)
EMERGENCY_LOSS_PCT=3.0            # Unrealized loss % of size_usd
EMERGENCY_PROFIT_PCT=5.0          # Unrealized profit % of size_usd
EMERGENCY_PRICE_MOVE_PCT=2.0      # Price move % within time window
EMERGENCY_PRICE_MOVE_MINUTES=5    # Time window for price move detection
EMERGENCY_COOLDOWN_MINUTES=15     # Min interval between emergency cycles

# Dashboard
DASHBOARD_PORT=8080

# Set to "true" to use Hyperliquid testnet instead of mainnet
TESTNET=false

# Set to "true" to skip real orders (simulate only)
DRY_RUN=true
