graph LR
    Trade["Trade<br/>Execution"] --> PTR["Post-Trade<br/>Reflection"]
    Trade --> HR["Hold<br/>Reflection<br/>(4h later)"]

    PTR --> Analysis["Chart +<br/>Result Analysis"]
    HR --> Missed["Missed<br/>Opportunity<br/>Analysis"]

    Analysis --> RuleUpdate["AGENTS.md<br/>Rule Update<br/>(max 10)"]
    Missed --> RuleUpdate

    Analysis --> HQ["Hypothesis<br/>Queue"]
    Missed --> HQ

    HQ -->|"2+ supports"| Promote["Promote<br/>to Rule"]
    HQ -->|"denied"| Delete["Delete"]
    Promote --> RuleUpdate

    RuleUpdate --> Consistency["Consistency<br/>Check<br/>(pseudo-code)"]
    Consistency --> Rules["Validated<br/>Rules"]

    PTR --> Digest["Reflection<br/>Digest<br/>(every 12h)"]
    HR --> Digest

    Digest --> Inject["Inject into<br/>MAGI Prompt"]
    Rules --> Inject
    Inject --> Trade

    style Trade fill:#1a1a2e,stroke:#58a6ff,stroke-width:2px
    style RuleUpdate fill:#1a1a2e,stroke:#e3b341,stroke-width:2px
    style HQ fill:#1a1a2e,stroke:#e3b341,stroke-width:2px
    style Promote fill:#238636,stroke:#2ea043
    style Delete fill:#da3633,stroke:#f85149
    style Rules fill:#1a1a2e,stroke:#e3b341,stroke-width:2px
